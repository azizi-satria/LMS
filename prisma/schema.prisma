generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOSEN
  MAHASISWA
  UMUM
}

enum MaterialType {
  VIDEO
  PDF
  DOCUMENT
  LINK
}

enum CourseVisibility {
  DRAFT
  INTERNAL
  PUBLIC
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MAHASISWA)
  nim       String?
  nip       String?
  createdAt DateTime @default(now())

  courses           Course[]           @relation("InstructorCourses")
  enrollments       Enrollment[]
  materialProgress  MaterialProgress[]
  approvalRequests  CourseApproval[]   @relation("ApprovalRequester")
  approvalReviews   CourseApproval[]   @relation("ApprovalReviewer")
  payments          Payment[]
  confirmedPayments Payment[]          @relation("PaymentConfirmer")

  @@map("users")
}

model Course {
  id           String           @id @default(cuid())
  title        String
  description  String
  instructorId String
  semester     String
  visibility   CourseVisibility @default(DRAFT)
  price        Int              @default(0)
  isApproved   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  instructor  User             @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  modules     Module[]
  enrollments Enrollment[]
  approvals   CourseApproval[]
  payments    Payment[]

  @@map("courses")
}

model Module {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int    @default(0)

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]

  @@map("modules")
}

model Material {
  id         String       @id @default(cuid())
  moduleId   String
  title      String
  type       MaterialType
  contentUrl String
  order      Int          @default(0)

  module   Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress MaterialProgress[]

  @@map("materials")
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model MaterialProgress {
  id          String   @id @default(cuid())
  userId      String
  materialId  String
  completedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@map("material_progress")
}

model CourseApproval {
  id               String           @id @default(cuid())
  courseId         String
  requestedBy      String
  targetVisibility CourseVisibility
  suggestedPrice   Int?
  requesterNotes   String?
  status           ApprovalStatus   @default(PENDING)
  adminNotes       String?
  finalPrice       Int?
  reviewedBy       String?
  createdAt        DateTime         @default(now())
  reviewedAt       DateTime?

  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  requester User    @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  reviewer  User?   @relation("ApprovalReviewer", fields: [reviewedBy], references: [id])

  @@map("course_approvals")
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  courseId    String
  amount      Int
  vaNumber    String        @unique
  bankName    String        @default("BCA Virtual Account")
  status      PaymentStatus @default(PENDING)
  confirmedBy String?
  confirmedAt DateTime?
  expiredAt   DateTime
  createdAt   DateTime      @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  confirmer User?   @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@unique([userId, courseId])
  @@map("payments")
}

model PlatformSettings {
  id            String   @id @default("global")
  bankName      String   @default("BCA Virtual Account")
  vaPrefix      String   @default("8808")
  vaExpiryHours Int      @default(24)
  updatedAt     DateTime @updatedAt

  @@map("platform_settings")
}
